# LLM (OpenAI SDK-compatible; DeepSeek in this setup)
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
# Flash = fast non-thinking (default), Pro = thinking/reasoning
LLM_MODEL=deepseek-v4-flash
LLM_MODEL_PRO=deepseek-v4-pro

# Kimi — alternate chat provider (agent-runtime). Image captioning has
# moved to MiniMax Coding Plan's /v1/coding_plan/vlm; these vars are still
# read by the chat path when provider=kimi is selected from the UI.
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_VISION_MODEL=moonshot-v1-8k-vision-preview

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_platform

# Redis
REDIS_URL=redis://localhost:6379

# Auth
AUTH_SECRET=change-me-in-production

# Agent runtime
AGENT_RUNTIME_URL=http://localhost:3001
MOCK_LLM=false

# MiniMax — one API key drives TTS, web search (Coding Plan), and image
# understanding (Coding Plan VLM). The TTS path lives on a different
# subdomain (api.minimax.chat) than the Coding Plan endpoints (mainland:
# api.minimaxi.com / global: api.minimax.io), so each has its own host var.
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
# TTS host. China: api.minimax.chat — international: api.minimax.io
MINIMAX_BASE_URL=https://api.minimax.chat/v1
# TTS model — defaults to speech-2.8-hd (covered by Plus 标准版).
# Override for higher tiers: speech-2.8-turbo / speech-02-hd / speech-02-turbo.
MINIMAX_TTS_MODEL=speech-2.8-hd
# Coding Plan host (web_search + understand_image / VLM caption).
# Mainland: api.minimaxi.com — Global: api.minimax.io
MINIMAX_CODING_PLAN_HOST=https://api.minimaxi.com
# Optional override: force a specific TTS provider regardless of which keys
# are configured. Useful for testing the mock path in prod.
TTS_PROVIDER=

# Web search (used by web_search / search_lyrics tools).
# Primary tries first; fallback runs only on primary error.
WEB_SEARCH_PRIMARY=minimax
WEB_SEARCH_FALLBACK=bocha
BOCHA_API_KEY=
TAVILY_API_KEY=

# Tencent Cloud COS (image uploads)
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-shanghai
