# === MUST CHANGE ===
AUTH_SECRET=generate-a-random-64-char-string-here
POSTGRES_PASSWORD=change-this-strong-password
LLM_API_KEY=sk-your-deepseek-key

# === LLM ===
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
MOCK_LLM=false

# === Internal (usually no need to change) ===
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@postgres:5432/agent_platform
REDIS_URL=redis://redis:6379
AGENT_RUNTIME_URL=http://agent-runtime:3001
