# === MUST CHANGE ===
AUTH_SECRET=generate-with-openssl-rand-hex-32
POSTGRES_PASSWORD=change-this-strong-password
LLM_API_KEY=sk-your-deepseek-key
# Signs the short-lived JWT agent-runtime sends back on tool callbacks.
# Generate with: openssl rand -base64 48
INTERNAL_JWT_SECRET=generate-with-openssl-rand-base64-48

# === LLM ===
LLM_BASE_URL=https://api.deepseek.com
# Flash = fast non-thinking (default), Pro = thinking/reasoning
LLM_MODEL=deepseek-v4-flash
LLM_MODEL_PRO=deepseek-v4-pro
MOCK_LLM=false

# === Vision (Kimi K2.6) — used only for image-understanding turns ===
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_VISION_MODEL=kimi-k2.6

# === Web search (web_search / search_lyrics / fetch_url tools) ===
# Primary tries first; fallback runs only on primary error. Bocha is
# CN-friendly + honors `site:` operator (needed for QQ Music links);
# Tavily covers English/Western sources better.
WEB_SEARCH_PRIMARY=bocha
WEB_SEARCH_FALLBACK=tavily
BOCHA_API_KEY=
TAVILY_API_KEY=

# === Tencent Cloud COS (image uploads — required for vision feature) ===
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=ap-guangzhou

# === Auth ===
AUTH_URL=http://119.29.129.198:3000

# === Database + Redis (localhost since they run on same machine) ===
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD_HERE@localhost:5432/agent_platform
REDIS_URL=redis://localhost:6379
AGENT_RUNTIME_URL=http://localhost:3001
# Public URL the agent-runtime callbacks POST to (same Next.js origin).
# Usually identical to AUTH_URL. Override if behind a different proxy.
WEB_BASE_URL=http://119.29.129.198:3000
GATEWAY_PORT=3002
NEXT_PUBLIC_GATEWAY_URL=http://119.29.129.198:3002

# === Optional ===
# Where pino log files go. Defaults to /root/agent-platform/logs — override if
# that path isn't writable (e.g. non-root deployments).
# LOG_DIR=/root/agent-platform/logs
# Memory dedup scan cadence. Default 86400000 (24h). Set to 120000 for a 2-min
# dev loop.
# MEMORY_DEDUP_INTERVAL_MS=86400000
